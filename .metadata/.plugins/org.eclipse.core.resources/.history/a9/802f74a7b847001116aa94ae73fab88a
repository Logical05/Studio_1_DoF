#ifndef SRC_USEFUL_H_
#define SRC_USEFUL_H_

#include <stdbool.h>

struct DelayTimer {
	uint32_t start;
	uint32_t duration;
	uint8_t active;
};

static void Timer_Start(struct DelayTimer *t, uint32_t ms) {
	t->start = HAL_GetTick();
	t->duration = ms;
	t->active = 1;
}
static uint8_t Timer_Expired(struct DelayTimer *t) {
	if (!t->active)
		return 0;

	if ((HAL_GetTick() - t->start) >= t->duration) {
		t->active = 0;
		return 1;
	}

	return 0;
}

long map(long x, long in_min, long in_max, long out_min, long out_max) {
	return (x - in_min) * (out_max - out_min) / (in_max - in_min) + out_min;
}

static void Max_Clamp(float *a, const float abs_max) {
	if (*a > abs_max)
		*a = abs_max;
	else if (*a < -abs_max)
		*a = -abs_max;
}

static float clamp(float x, float min, float max) {
	if (x < min)
		return min;
	if (x > max)
		return max;
	return x;
}

#endif /* SRC_USEFUL_H_ */
