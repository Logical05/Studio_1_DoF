#include "useful.h"

static void Timer_Start(struct DelayTimer *t, uint32_t ms) {
	t->start = HAL_GetTick();
	t->duration = ms;
	t->active = true;
}
static bool Timer_Expired(struct DelayTimer *t) {
	if (!t->active)
		return false;

	if ((HAL_GetTick() - t->start) >= t->duration) {
		t->active = false;
		return true;
	}

	return false;
}

long map(long x, long in_min, long in_max, long out_min, long out_max) {
	return (x - in_min) * (out_max - out_min) / (in_max - in_min) + out_min;
}

static void Max_Clamp(float *a, const float abs_max) {
	if (*a > abs_max)
		*a = abs_max;
	else if (*a < -abs_max)
		*a = -abs_max;
}

static float clamp(float x, float min, float max) {
	if (x < min)
		return min;
	if (x > max)
		return max;
	return x;
}
