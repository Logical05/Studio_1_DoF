#include "pid.h"

static void Max_Clamp(float *a, const float abs_max) {
	if (*a > abs_max)
		*a = abs_max;
	else if (*a < -abs_max)
		*a = -abs_max;
}

void PID_Init(struct PID_TypeDef *pid, float kp, float ki, float kd,
		float max_output, bool anti_windup, float integral_limit) {
	pid->max_output = max_output;
	pid->integral_limit = integral_limit;
	pid->anti_windup = anti_windup;

	PID_Reset(pid, kp, ki, kd);
}

void PID_Reset(struct PID_TypeDef *pid, float kp, float ki, float kd) {
	pid->kp = kp;
	pid->ki = ki;
	pid->kd = kd;
	pid->error[NOW] = 0.0f;
	pid->error[LAST] = 0.0f;

	pid->p_out = 0.0f;
	pid->i_out = 0.0f;
	pid->d_out = 0.0f;
	pid->output = 0.0f;

	if (pid->anti_windup && ki == 0.0f)
		pid->anti_windup = false;
}

void PID_Calc(struct PID_TypeDef *pid, float setpoint, float process) {
	pid->Error[NOW] = setpoint - process;

	pid->P_out = pid->Kp * pid->Error[NOW];
	pid->I_out += pid->Ki * pid->Error[NOW];
	pid->D_out = pid->Kd * (pid->Error[NOW] - pid->Error[LAST]);

	// Integral Limit
	Max_Clamp(&pid->I_out, pid->Integral_Limit);

	// Anti-Windup Clamp
	bool positive = pid->Output >= pid->Max_Output
			&& pid->Output * pid->Error[NOW] > 0;
	bool negative = pid->Output <= pid->Max_Output
			&& pid->Output * pid->Error[NOW] < 0;
	if (pid->Anti_Windup && (positive || negative)) {
		pid->I_out = 0.0f;
	}

	pid->Output = pid->P_out + pid->I_out + pid->D_out;
	Max_Clamp(&pid->Output, pid->Max_Output);

	pid->Error[LAST] = pid->Error[NOW];
}
