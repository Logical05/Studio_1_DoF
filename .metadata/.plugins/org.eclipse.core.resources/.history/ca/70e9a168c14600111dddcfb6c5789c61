#ifndef INC_PID_H_
#define INC_PID_H_

#include <math.h>

struct PID_TypeDef {
	float P;
	float I;
	float D;
	float Error[2];

	float P_out;
	float I_out;
	float D_out;

	float Output;
	float Max_Output;

	float Integral_Limit;
};

void PID_Init(struct PID_TypeDef *pid, float p, float i, float d, float max_output =
		INFINITY, float integral_limit = INFINITY);

void PID_Reset(struct PID_TypeDef *pid, float p, float i, float d)

void PID_Calc(struct PID_TypeDef *pid, float setpoint, float process);

#endif /* INC_PID_H_ */
