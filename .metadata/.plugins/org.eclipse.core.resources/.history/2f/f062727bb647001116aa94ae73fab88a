void Timer_Start(struct DelayTimer *t, uint32_t ms) {
	t->start = HAL_GetTick();
	t->duration = ms;
	t->active = 1;
}
uint8_t Timer_Expired(struct DelayTimer *t) {
	if (!t->active)
		return 0;

	if ((HAL_GetTick() - t->start) >= t->duration) {
		t->active = 0;
		return 1;
	}

	return 0;
}
