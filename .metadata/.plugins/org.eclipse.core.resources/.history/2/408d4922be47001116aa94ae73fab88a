#ifndef SRC_USEFUL_H_
#define SRC_USEFUL_H_

#include "stm32g4xx_hal.h"
#include <stdbool.h>

struct DelayTimer {
	uint32_t start;
	uint32_t duration;
	bool active;
};

static void Timer_Start(struct DelayTimer *t, uint32_t ms) {
	t->start = HAL_GetTick();
	t->duration = ms;
	t->active = true;
}

static bool Timer_Expired(struct DelayTimer *t) {
	if (!t->active)
		return false;

	if ((HAL_GetTick() - t->start) >= t->duration) {
		t->active = false;
		return true;
	}

	return false;
}

static float map(float x, float in_min, float in_max, float out_min,
		float out_max) {
	return (x - in_min) * (out_max - out_min) / (in_max - in_min) + out_min;
}

static float clamp(float x, float min, float max) {
	if (x < min)
		return min;
	if (x > max)
		return max;
	return x;
}

static float clamp_max(float x, float max) {
	if (x < min)
		return min;
	if (x > max)
		return max;
	return x;
}

#endif /* SRC_USEFUL_H_ */
