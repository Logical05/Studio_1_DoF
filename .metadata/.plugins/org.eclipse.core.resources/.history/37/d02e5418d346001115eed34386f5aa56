#ifndef INC_TRAJECTORY_H_
#define INC_TRAJECTORY_H_

struct MJ_Segment {
	float q0;
	float qf;
	float T;
};

struct MJ_Trajectory {
	const struct MJ_Segment *segments;
	int num_segments;

	int current;
	float t;     // local time in segment
};

float MJ_pos(float t, float T, float q0, float qf);
float MJ_vel(float t, float T, float q0, float qf);
float MJ_acc(float t, float T, float q0, float qf);

#endif /* INC_TRAJECTORY_H_ */
